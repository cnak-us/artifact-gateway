# artifact-gateway local-dev environment.
#
# Copy this file to `.env` and fill in the secret values, or run
# `make dev-init` to have them generated automatically.
#
# `.env` is gitignored — never commit real secrets.

# -----------------------------------------------------------------------------
# Listeners
# -----------------------------------------------------------------------------
# PUBLIC_PORT      — OCI + UI + admin REST (/v2, /admin, /catalog, /api/v1)
# MANAGEMENT_PORT  — health probes + Prometheus /metrics
PUBLIC_PORT=8080
MANAGEMENT_PORT=8090

# Hostname customers will type in `docker login`. MUST exactly match the cert SAN
# in production — mismatch surfaces as an opaque `x509:` error to clients.
EXTERNAL_HOSTNAME=localhost:8080

# -----------------------------------------------------------------------------
# TLS (optional)
# -----------------------------------------------------------------------------
# In production TLS is normally terminated upstream (LB / Cloudflare) and these
# are left blank — the public listener serves plain HTTP behind the proxy.
#
# Set both to enable in-process HTTPS on the public listener. Two intended uses:
#   - local dev: `make dev-https` issues an mkcert-signed cert into ./certs/
#     and exports these vars for you (no need to edit this file).
#   - clusters without an upstream TLS terminator: mount a Kubernetes TLS
#     Secret onto the pod and point these at the mounted file paths.
#
# The management listener (health + /metrics) is always HTTP and ignores these.
TLS_CERT_FILE=
TLS_KEY_FILE=

# -----------------------------------------------------------------------------
# Local registry stand-in (compose only)
# -----------------------------------------------------------------------------
# REGISTRY_HOST_PORT — host-side port for the local registry:2 stand-in. Used by
# tests and exercised via an `oci-basic` upstream credential pointing at
# http://registry:5000 (inside the compose net) or http://localhost:${REGISTRY_HOST_PORT}
# (from the host). 5050 default because macOS AirPlay Receiver grabs 5000;
# free 5000 in System Settings → General → AirDrop & Handoff → AirPlay Receiver
# if you want the canonical port.
REGISTRY_HOST_PORT=5050

# -----------------------------------------------------------------------------
# Postgres
# -----------------------------------------------------------------------------
# When running `go run .` against the compose-managed Postgres, the host is
# `localhost`. Inside the compose network it's `postgres` (compose.yml
# overrides this var for the in-container service).
DATABASE_URL=postgres://postgres:postgres@localhost:5432/artifact_gateway?sslmode=disable

# -----------------------------------------------------------------------------
# NATS (optional — leave blank to disable audit fanout + license-cache invalidation)
# -----------------------------------------------------------------------------
NATS_URL=
NATS_CREDENTIALS_FILE=
NATS_AUTH_TOKEN=

# -----------------------------------------------------------------------------
# Secrets
#
# Generate fresh for local with:
#   KEK_BASE64=$(openssl rand -base64 32)
#   SESSION_SIGNING_KEY=$(openssl rand -hex 32)
#   JWT_SIGNING_KEY=$(openssl rand -hex 32)
#
# Or just run `make dev-init` and it will fill these in for you.
# -----------------------------------------------------------------------------
# 32 random bytes, base64. AES-GCM key-encryption-key for stored ghcr PATs.
KEK_BASE64=
# 32 random bytes, hex. HMAC-SHA256 for admin/catalog signed-cookie sessions.
SESSION_SIGNING_KEY=
# 32 random bytes, hex. HMAC-SHA256 for OCI bearer JWTs minted by /v2/token.
JWT_SIGNING_KEY=
# Shared secret used by the upstream-proxy path to call /api/v1 internally.
SERVICE_TOKEN=local-dev-service-token

# -----------------------------------------------------------------------------
# OCI bearer JWT lifetime (seconds) — clients re-mint when expired.
# -----------------------------------------------------------------------------
TOKEN_TTL_SECONDS=300

# -----------------------------------------------------------------------------
# Bootstrap admin account — created on first startup if no users exist.
# Change the password immediately after first login.
# -----------------------------------------------------------------------------
ADMIN_BOOTSTRAP_EMAIL=admin@local.dev
ADMIN_BOOTSTRAP_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Declarative bootstrap manifest (optional).
#
# When set, the gateway reads this YAML at startup and reconciles it against
# the DB. The shipped `config/standard.yaml` declares every cnak/ artifact
# (containers, helm chart, binaries, compose bundle) under two upstream
# credentials sourced from GHCR_PAT + GITHUB_API_PAT.
#
# `make reset` wipes the DB volume; on the next `make dev` boot this re-seeds
# the catalog automatically — that is the "easy reset" loop.
#
# Set CONFIG_FILE_PRUNE=true to ALSO delete DB rows the manifest no longer
# declares. (Be aware of the prune defects logged in apply/reconcile.go —
# only static_admin pruning is currently safe; other kinds may delete rows
# created via the admin UI.)
# -----------------------------------------------------------------------------
CONFIG_FILE=
CONFIG_FILE_PRUNE=false
GHCR_PAT=
GITHUB_API_PAT=

# -----------------------------------------------------------------------------
# OIDC
# -----------------------------------------------------------------------------
# If true, OIDC logins for unknown emails are auto-provisioned as role=viewer
# (admin must then promote them). Default false.
OIDC_AUTOPROVISION=false

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=debug
LOG_FORMAT=text

# -----------------------------------------------------------------------------
# Dex shim (only used when running `docker compose --profile dex` / `make dev-dex`).
# Create a GitHub OAuth App at https://github.com/settings/developers with:
#   Authorization callback URL: http://localhost:5556/callback
# Paste its client id + secret here. See DEX.md for the full setup.
# -----------------------------------------------------------------------------
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
